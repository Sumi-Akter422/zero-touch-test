#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Zero Touch -- commit-msg hook
#  Format: SBC-001: description
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
SERVER_URL="http://localhost:3001"

# ── Format validation ──────────────────────────
# Valid: SBC-001: fix login bug
PATTERN="^[A-Z]+-[0-9]+: .{5,}"

if echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo -e "\n${GREEN}${BOLD}[OK] Zero Touch: Commit message valid${RESET}\n"
  exit 0
fi

# ── Error display ──────────────────────────────
echo ""
echo -e "${RED}${BOLD}[ERROR] Zero Touch: Invalid commit message.${RESET}"
echo -e "   ${BOLD}Your message:${RESET}  ${RED}\"${COMMIT_MSG}\"${RESET}"
echo -e "   ${BOLD}Required:${RESET}      ${YELLOW}SBC-001: description${RESET}"
echo ""

# ── Ask AI for suggestion ──────────────────────
echo -e "${CYAN}Loading AI suggestion...${RESET}"

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
TICKET=$(echo "$BRANCH" | grep -oE '^[A-Z]+-[0-9]+' || echo "")

AI_RESPONSE=$(curl -s --max-time 8 \
  -X POST "${SERVER_URL}/api/hooks/commit-suggest" \
  -H "Content-Type: application/json" \
  -d "{\"message\": $(echo "$COMMIT_MSG" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || echo "\"${COMMIT_MSG}\""), \"branch\": \"${BRANCH}\", \"ticket\": \"${TICKET}\"}" \
  2>/dev/null)

SUGGESTION=""

if [ -n "$AI_RESPONSE" ]; then
  SUGGESTION=$(echo "$AI_RESPONSE" | grep -o '"suggestion":"[^"]*"' | sed 's/"suggestion":"//;s/"$//' 2>/dev/null)
fi

# ── Fallback: build suggestion locally ────────
if [ -z "$SUGGESTION" ]; then
  if [ -n "$TICKET" ]; then
    CLEAN_MSG=$(echo "$COMMIT_MSG" | sed 's/^[a-z]*:*\s*//' | sed 's/^\s*//')
    SUGGESTION="${TICKET}: ${CLEAN_MSG}"
  else
    SUGGESTION="SBC-001: ${COMMIT_MSG}"
  fi
fi

echo ""
echo -e "${CYAN}${BOLD}AI Suggestion:${RESET} ${CYAN}\"${SUGGESTION}\"${RESET}"
echo ""
echo -ne "${BOLD}Press Y to apply [Y/n]: ${RESET}"

exec < /dev/tty
read -r REPLY

if [[ "$REPLY" =~ ^[Yy]$|^$ ]]; then
  echo "$SUGGESTION" > "$COMMIT_MSG_FILE"
  echo ""
  echo -e "${GREEN}${BOLD}[OK] Commit message updated:${RESET} ${GREEN}\"${SUGGESTION}\"${RESET}"
  echo ""
  exit 0
else
  echo ""
  echo -e "${RED}${BOLD}[ABORT] Commit cancelled.${RESET} Fix the message and try again."
  echo -e "   ${YELLOW}Example: git commit -m \"${SUGGESTION}\"${RESET}"
  echo ""
  exit 1
fi
