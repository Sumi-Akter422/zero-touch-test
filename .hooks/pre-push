#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Zero Touch -- pre-push hook
#  - Branch name format validation
#  - .env file block
#  - Secret leak scan
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

REMOTE="$1"
BLOCKED=0

echo ""
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${CYAN}${BOLD}  Zero Touch -- Pre-Push Guard${RESET}"
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ── 1. Branch name format ──────────────────────
# Valid: SBC-001-stage | SBC-001-release | main | develop
echo ""
echo -e "${BOLD}  [1] Branch Name Check${RESET}"

BRANCH_PATTERN="^([A-Z]+-[0-9]+-(stage|release|dev|hotfix))$|^(main|master|develop)$"

if echo "$BRANCH" | grep -qE "$BRANCH_PATTERN"; then
  echo -e "  ${GREEN}[OK]${RESET}  Branch '${BRANCH}' -- format valid"
else
  echo -e "  ${RED}${BOLD}[ERROR] Zero Touch: Invalid branch name.${RESET}"
  echo -e "     ${BOLD}Your branch:${RESET} ${RED}\"${BRANCH}\"${RESET}"
  echo -e "     ${BOLD}Required:${RESET}    ${YELLOW}SBC-001-stage  OR  SBC-001-release${RESET}"
  echo ""
  echo -e "  ${YELLOW}Rename your branch:${RESET}"
  echo -e "  ${CYAN}git branch -m ${BRANCH} SBC-001-stage${RESET}"
  BLOCKED=1
fi

# ── 2. .env file protection ────────────────────
echo ""
echo -e "${BOLD}  [2] .env File Protection${RESET}"

ENV_TRACKED=$(git ls-files | grep -E '(^|/)\.env(\.|$)' || true)

if [ -n "$ENV_TRACKED" ]; then
  echo -e "  ${RED}${BOLD}[ERROR] Zero Touch: .env file is tracked by git!${RESET}"
  echo ""
  echo -e "  ${RED}Tracked .env files:${RESET}"
  echo "$ENV_TRACKED" | while read -r f; do
    echo -e "     ${RED}-> ${f}${RESET}"
  done
  echo ""
  echo -e "  ${YELLOW}${BOLD}Fix it:${RESET}"
  echo -e "  ${CYAN}echo \".env\" >> .gitignore${RESET}"
  echo -e "  ${CYAN}git rm --cached .env${RESET}"
  echo -e "  ${CYAN}git commit -m \"SBC-001: remove .env from tracking\"${RESET}"
  echo ""
  echo -e "  ${RED}${BOLD}This check cannot be bypassed.${RESET}"
  BLOCKED=1
else
  echo -e "  ${GREEN}[OK]${RESET}  No .env file tracked -- safe"
fi

# ── 3. Secret leak scan ────────────────────────
echo ""
echo -e "${BOLD}  [3] Secret Leak Scan${RESET}"

PUSHED_DIFF=$(git diff HEAD @{u} 2>/dev/null || git diff HEAD~1 HEAD 2>/dev/null || true)
SECRET_FOUND=0

if [ -n "$PUSHED_DIFF" ]; then
  PATTERNS=(
    'password\s*=\s*["\x27][^"\x27]{4,}'
    'api[_-]?key\s*=\s*["\x27][^"\x27]{8,}'
    'secret\s*=\s*["\x27][^"\x27]{8,}'
    'AWS_SECRET_ACCESS_KEY\s*='
    'token\s*=\s*["\x27][^"\x27]{8,}'
    'DATABASE_URL\s*='
  )

  for pattern in "${PATTERNS[@]}"; do
    if echo "$PUSHED_DIFF" | grep -iEq "$pattern"; then
      echo -e "  ${RED}${BOLD}[ERROR] Possible secret detected (pattern: ${pattern})${RESET}"
      SECRET_FOUND=1
      BLOCKED=1
    fi
  done

  if [ $SECRET_FOUND -eq 0 ]; then
    echo -e "  ${GREEN}[OK]${RESET}  No hardcoded secrets found"
  fi
else
  echo -e "  ${GREEN}[OK]${RESET}  Nothing to diff -- skipped"
fi

# ── Summary ────────────────────────────────────
echo ""
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

if [ "$BLOCKED" -eq 1 ]; then
  echo -e "${RED}${BOLD}  [BLOCKED] Push rejected. Fix the errors above and try again.${RESET}"
  echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo ""
  exit 1
fi

echo -e "${GREEN}${BOLD}  [OK] All checks passed -- pushing to ${REMOTE}${RESET}"
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""
exit 0
